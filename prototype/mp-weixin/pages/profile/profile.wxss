/* 对齐 client tags-screen / .lx-label / .tags-body */
.label {
  display: block;
  margin-top: 28rpx;
  font-size: 20rpx;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #a8a29e;
}

.row:first-of-type .label {
  margin-top: 0;
}

.picker {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #e7e5e4;
  font-size: 28rpx;
}

.row {
  margin-top: 8rpx;
}
