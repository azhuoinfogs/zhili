.landing {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 48rpx 40rpx 32rpx;
  box-sizing: border-box;
}

.landing-bg {
  position: fixed;
  inset: 0;
  background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(202, 138, 4, 0.12), transparent 55%),
    radial-gradient(ellipse 60% 40% at 80% 100%, rgba(87, 83, 78, 0.15), transparent 50%);
  pointer-events: none;
  z-index: 0;
}

.landing-top,
.landing-center,
.landing-foot {
  position: relative;
  z-index: 1;
}

.landing-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 80rpx;
}

.pill-ab {
  font-size: 20rpx;
  letter-spacing: 0.25em;
  color: #ca8a04;
  border: 1rpx solid rgba(202, 138, 4, 0.35);
  padding: 12rpx 24rpx;
}

.landing-refine {
  font-size: 22rpx;
  color: #78716c;
  letter-spacing: 0.08em;
}

.landing-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 40rpx;
}

.landing-eyebrow {
  font-size: 22rpx;
  letter-spacing: 0.35em;
  color: #a8a29e;
  margin-bottom: 24rpx;
}

.landing-title {
  font-size: 96rpx;
  font-weight: 300;
  color: #fafaf9;
  letter-spacing: 0.2em;
  margin-bottom: 16rpx;
}

.font-serif {
  font-family: 'Songti SC', 'SimSun', serif;
}

.landing-sub {
  font-size: 36rpx;
  color: #ca8a04;
  letter-spacing: 0.5em;
  margin-bottom: 48rpx;
}

.landing-lead {
  font-size: 28rpx;
  line-height: 1.75;
  color: #a8a29e;
  max-width: 600rpx;
  margin-bottom: 64rpx;
  white-space: pre-line;
}

.cta-explore {
  width: 100%;
  max-width: 520rpx;
  padding: 32rpx 48rpx;
  background: transparent;
  color: #fafaf9;
  border: 2rpx solid #ca8a04;
  border-radius: 0;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.35em;
  margin-bottom: 40rpx;
}

.cta-explore::after {
  border: none;
}

.landing-hint {
  font-size: 22rpx;
  color: #57534e;
  line-height: 1.6;
  max-width: 560rpx;
}

.landing-foot {
  text-align: center;
  font-size: 20rpx;
  color: #44403c;
  padding-top: 48rpx;
  letter-spacing: 0.06em;
}
