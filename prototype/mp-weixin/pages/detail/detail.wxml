<view wx:if="{{product}}" class="detail-wrap">
  <swiper
    wx:if="{{imageUrls.length > 1}}"
    class="hero-swiper"
    indicator-dots
    indicator-color="rgba(255,255,255,0.25)"
    indicator-active-color="#ca8a04"
    bindchange="onSwiperChange"
  >
    <swiper-item wx:for="{{imageUrls}}" wx:key="*this">
      <image class="hero" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>
  <image wx:else class="hero" src="{{imageUrls[0] || product.image}}" mode="aspectFill" />

  <view class="card">
    <view class="title">{{product.title}}</view>
    <view class="price">¥{{product.price}}</view>
    <view wx:for="{{product.reasons}}" wx:key="index" wx:for-item="r" class="reason">{{r.icon}} {{r.text}}</view>
    <button class="btn-secondary" bindtap="onCollect">收录礼遇单</button>
    <button class="btn-primary" bindtap="onBuy">去购买（占位）</button>
  </view>

  <view wx:if="{{related.length}}" class="related-block">
    <text class="related-title">相关推荐</text>
    <scroll-view scroll-x class="related-scroll" enable-flex>
      <view
        class="related-card"
        wx:for="{{related}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="openRelated"
      >
        <image class="related-img" src="{{item.image}}" mode="aspectFill" />
        <text class="related-name">{{item.title}}</text>
      </view>
    </scroll-view>
  </view>
</view>
<view wx:else class="hint">未找到商品</view>
