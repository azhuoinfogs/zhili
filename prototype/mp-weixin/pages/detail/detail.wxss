/* 对齐 client modal / .detail-name / .detail-price / .reason-glass */
.detail-wrap {
  padding-bottom: 140rpx;
}

.hero-swiper {
  width: 100%;
  height: 480rpx;
}

.card {
  margin-top: 0;
}

.hero {
  width: 100%;
  height: 480rpx;
  display: block;
  background: #292524;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  margin-top: 28rpx;
  letter-spacing: 0.08em;
  color: #fafaf9;
}

.price {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #eab308;
}

.reason {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(202, 138, 4, 0.15);
  background: rgba(202, 138, 4, 0.06);
  border-radius: 4rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #d6d3d1;
}

.btn-secondary {
  margin: 32rpx 32rpx 0;
  padding: 24rpx 40rpx;
  background: rgba(202, 138, 4, 0.12);
  color: #eab308 !important;
  border: 1rpx solid rgba(202, 138, 4, 0.35) !important;
  border-radius: 0;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.15em;
}

button.btn-secondary::after {
  border: none;
}

.related-block {
  margin: 40rpx 24rpx 0;
}

.related-title {
  display: block;
  font-size: 26rpx;
  color: #a8a29e;
  letter-spacing: 0.2em;
  margin-bottom: 20rpx;
}

.related-scroll {
  white-space: nowrap;
  width: 100%;
}

.related-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 20rpx;
  vertical-align: top;
  background: rgba(28, 25, 23, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.related-img {
  width: 200rpx;
  height: 200rpx;
  background: #292524;
}

.related-name {
  font-size: 22rpx;
  color: #d6d3d1;
  padding: 12rpx;
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.hint {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #78716c;
  font-size: 28rpx;
}

.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #1c1917;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #78716c;
  letter-spacing: 0.05em;
}

.tab-item:active .tab-text {
  color: #eab308;
}
