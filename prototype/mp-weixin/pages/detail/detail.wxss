/* 详情页样式 - 对齐 client modal */
.detail-wrap {
  padding-bottom: 140rpx;
  min-height: 100vh;
}

/* 商品图片区域 */
.hero-swiper {
  width: 100%;
  height: 600rpx;
  background: #0c0a09;
}

.hero {
  width: 100%;
  height: 600rpx;
  display: block;
  background: #292524;
}

/* 商品信息卡片 */
.card {
  margin: 24rpx;
  padding: 36rpx;
  border-radius: 12rpx;
}

/* 商品头部 */
.product-header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: #fafaf9;
  line-height: 1.4;
}

.font-serif {
  font-family: 'Georgia', 'Times New Roman', serif;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 500;
  color: #eab308;
  margin-right: 4rpx;
}

.price {
  font-size: 56rpx;
  font-weight: 700;
  color: #eab308;
  letter-spacing: 0.02em;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.06);
  margin: 28rpx 0;
}

/* 推荐理由区域 */
.reasons-section {
  margin-bottom: 32rpx;
}

.section-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 24rpx;
  letter-spacing: 0.2em;
  color: #a8a29e;
  text-transform: uppercase;
}

.reasons-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reason-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: rgba(202, 138, 4, 0.08);
  border: 1rpx solid rgba(202, 138, 4, 0.2);
  border-radius: 8rpx;
}

.reason-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.reason-text {
  font-size: 28rpx;
  color: #d6d3d1;
  line-height: 1.6;
}

/* 商品描述 */
.desc-section {
  margin-bottom: 32rpx;
}

.description {
  font-size: 28rpx;
  color: #a8a29e;
  line-height: 1.7;
  white-space: pre-wrap;
}

/* 标签区域 */
.tags-section {
  margin-bottom: 32rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  padding: 12rpx 24rpx;
  background: rgba(202, 138, 4, 0.12);
  border: 1rpx solid rgba(202, 138, 4, 0.3);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #eab308;
  letter-spacing: 0.08em;
}

/* 操作按钮区域 */
.actions-row {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn-outline {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: transparent !important;
  color: #a8a29e !important;
  border: 2rpx solid rgba(255, 255, 255, 0.15) !important;
  border-radius: 8rpx;
  font-size: 26rpx;
  letter-spacing: 0.1em;
}

button.btn-outline::after {
  border: none;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-gold {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(202, 138, 4, 0.2), rgba(202, 138, 4, 0.05)) !important;
  color: #eab308 !important;
  border: 2rpx solid rgba(202, 138, 4, 0.5) !important;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.15em;
}

button.btn-gold::after {
  border: none;
}

/* 相关推荐区域 */
.related-block {
  margin: 32rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: #fafaf9;
}

.section-sub {
  font-size: 22rpx;
  color: #78716c;
  letter-spacing: 0.1em;
}

.related-scroll {
  white-space: nowrap;
  width: 100%;
  padding-bottom: 8rpx;
}

.related-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  margin-right: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.related-img {
  width: 240rpx;
  height: 240rpx;
  background: #292524;
}

.related-info {
  padding: 16rpx;
}

.related-name {
  font-size: 24rpx;
  color: #d6d3d1;
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}

.related-price {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #eab308;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #fafaf9;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #78716c;
  margin-bottom: 32rpx;
  text-align: center;
}

/* 底部导航 - 与原生 tabBar 保持一致 */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #1c1917;
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  transition: opacity 0.2s ease;
}

.tab-item:active {
  opacity: 0.7;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #78716c;
  letter-spacing: 0.08em;
  transition: color 0.2s ease;
}

.tab-item.active .tab-icon {
  filter: brightness(1.2);
}

.tab-item.active .tab-text {
  color: #eab308;
}

/* 动画效果 */
.animate-fadeIn {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}