/* 对齐 client modal / .detail-name / .detail-price / .reason-glass */
.card {
  margin-top: 0;
}

.hero {
  width: 100%;
  height: 480rpx;
  display: block;
  background: #292524;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  margin-top: 28rpx;
  letter-spacing: 0.08em;
  color: #fafaf9;
}

.price {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #eab308;
}

.reason {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(202, 138, 4, 0.15);
  background: rgba(202, 138, 4, 0.06);
  border-radius: 4rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #d6d3d1;
}

.hint {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #78716c;
  font-size: 28rpx;
}
