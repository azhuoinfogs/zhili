/* 对齐 client .browse / .grid / .product-card / .p-title / .p-price */
.list {
  min-height: 100vh;
  background: #0c0a09;
  box-sizing: border-box;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 12rpx 32rpx;
}

.item {
  width: calc(50% - 24rpx);
  margin: 8rpx;
  padding: 0;
  overflow: hidden;
  background: rgba(28, 25, 23, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.35);
}

.img {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #292524;
}

.title {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.45;
  color: #e7e5e4;
  padding: 20rpx 20rpx 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.price {
  margin-top: 12rpx;
  padding: 0 20rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #eab308;
  letter-spacing: 0.06em;
}

.hint {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #78716c;
  font-size: 26rpx;
  letter-spacing: 0.08em;
}
