<view wx:if="{{loading}}" class="hint">加载中…</view>
<scroll-view scroll-y class="list" wx:else>
  <view class="grid">
    <view class="item card" wx:for="{{products}}" wx:key="id" wx:for-item="p" data-id="{{p.id}}" bindtap="openDetail">
      <image class="img" src="{{p.image}}" mode="aspectFill" />
      <view class="title">{{p.title}}</view>
      <view class="price">¥{{p.price}}</view>
    </view>
  </view>
</scroll-view>
