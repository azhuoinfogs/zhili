/* 浏览页面样式 - 对齐 client .browse-screen */
.browse-screen {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: #0c0a09;
  box-sizing: border-box;
}

/* 玻璃卡片效果 */
.glass {
  background: rgba(28, 25, 23, 0.55);
  backdrop-filter: blur(36rpx);
  -webkit-backdrop-filter: blur(36rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.4);
}

/* 头部区域 */
.browse-head {
  margin: 24rpx;
  padding: 32rpx;
}

.link-ghost {
  background: transparent;
  color: #a8a29e;
  font-size: 26rpx;
  padding: 0;
  margin-bottom: 20rpx;
  text-align: left;
  border: none;
  letter-spacing: 0.08em;
}

.link-ghost::after {
  border: none;
}

.link-ghost:active {
  color: #eab308;
}

.browse-title {
  display: block;
  font-size: 44rpx;
  color: #fafaf9;
  letter-spacing: 0.15em;
  margin-bottom: 12rpx;
}

.font-serif {
  font-family: 'Georgia', 'Times New Roman', 'Songti SC', 'SimSun', serif;
}

.browse-meta {
  display: block;
  font-size: 24rpx;
  color: #78716c;
  letter-spacing: 0.1em;
}

/* 筛选栏 */
.filter-bar {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
}

.filter-eyebrow {
  font-size: 20rpx;
  letter-spacing: 0.4em;
  color: #ca8a04;
  margin-bottom: 20rpx;
  display: block;
}

.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-row:last-of-type {
  margin-bottom: 16rpx;
}

.filter-label {
  width: 100rpx;
  font-size: 22rpx;
  color: #a8a29e;
  letter-spacing: 0.08em;
}

.lx-input.sm {
  flex: 1;
  padding: 18rpx 24rpx;
  background: rgba(12, 10, 9, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 6rpx;
  color: #e7e5e4;
  font-size: 26rpx;
}

.filter-clear {
  margin-top: 8rpx;
  background: transparent;
  color: #ca8a04;
  font-size: 24rpx;
  border: 1rpx solid rgba(202, 138, 4, 0.4);
  border-radius: 6rpx;
  padding: 14rpx 32rpx;
  letter-spacing: 0.08em;
}

.filter-clear::after {
  border: none;
}

.filter-clear:active {
  background: rgba(202, 138, 4, 0.1);
}

/* 商品网格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  box-sizing: border-box;
}

.product-card {
  width: 47%;
  margin: 1.5%;
  padding: 0;
  overflow: hidden;
  border-radius: 12rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-sizing: border-box;
}

.product-card:active {
  transform: scale(0.98);
}

.img {
  width: 100%;
  height: 340rpx;
  display: block;
  background: #292524;
}

.info {
  padding: 20rpx 20rpx 24rpx;
}

.product-card .title {
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.45;
  color: #e7e5e4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  letter-spacing: 0.04em;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.price-symbol {
  font-size: 22rpx;
  font-weight: 500;
  color: #eab308;
  margin-right: 4rpx;
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #eab308;
  letter-spacing: 0.04em;
}

.p-reason {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  background: rgba(202, 138, 4, 0.08);
  border-radius: 4rpx;
  font-size: 22rpx;
  color: #a8a29e;
  line-height: 1.4;
}

.reason-icon {
  margin-right: 8rpx;
}

/* 加载状态 */
.hint {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #78716c;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  margin: 60rpx 24rpx;
  padding: 64rpx 40rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 36rpx;
  color: #e7e5e4;
  margin-bottom: 16rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #78716c;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.cta-outline {
  background: transparent;
  color: #eab308;
  border: 2rpx solid #ca8a04;
  border-radius: 6rpx;
  font-size: 26rpx;
  padding: 22rpx 48rpx;
  letter-spacing: 0.1em;
}

.cta-outline::after {
  border: none;
}

.cta-outline:active {
  background: rgba(202, 138, 4, 0.1);
}

/* 加载完成提示 */
.end-hint {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #57534e;
  letter-spacing: 0.1em;
}

/* 骨架屏 */
.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
}

.skeleton-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background: rgba(28, 25, 23, 0.55);
  border-radius: 12rpx;
  overflow: hidden;
}

.skeleton-img {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(90deg, #292524 25%, #1c1917 50%, #292524 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #3d3a38 25%, #292524 50%, #3d3a38 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  margin: 16rpx 20rpx 0;
  border-radius: 4rpx;
}

.skeleton-line.w50 {
  width: 50%;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 下拉刷新 */
.pull-indicator {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #a8a29e;
}

/* 加载更多 */
.load-more-bar {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #78716c;
}