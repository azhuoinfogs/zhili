{
  "info": {
    "_postman_id": "c4f8a1b2-3d5e-6f70-8a9b-0c1d2e3f4a5b",
    "name": "知礼 prototype（B0+B1+B2+B3+B4+B5+B6+B7+B9+验证流）",
    "description": "与仓库 api.md §10 一致。导入后请设置 Collection Variable `base_url`（含端口）；`token` 由 Login Tests 写入；B2 的 `profile_id` 可由「POST /api/profile (B2)」Tests 写入。B3/B4 需先有一条默认画像。B5「GET /api/product/:id」可不登录；带 Bearer 时需默认画像以生成匹配理由。B6 收藏需 **MySQL + seed**。B7：`POST /api/event` 需 MySQL；可选 Bearer；`EVENT_DB_DUAL_WRITE=1` 时 `POST /api/collect` 会双写 `event`。B9：`/api/admin/products*` 需 Bearer；服务端配置 **`ZHILI_ADMIN_USER_IDS`**（与 `/api/user/me` 的 `user.id` 一致）或 **`ZHILI_DEV_ADMIN_ANY_USER=1`**（仅本地）。B4/B5 可选 Redis（`npm run dev:db`）。B1/B2/B3/B4/B6 需 MySQL + `.env` 中 `WECHAT_MOCK=1` 或微信密钥。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:3000" },
    { "key": "token", "value": "" },
    { "key": "profile_id", "value": "" }
  ],
  "item": [
    {
      "name": "GET /api/health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/health",
        "description": "检查 database、auth_configured、jwt_strong_secret 等。"
      }
    },
    {
      "name": "POST /api/user/login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  try {",
              "    const j = pm.response.json();",
              "    if (j.token) pm.collectionVariables.set('token', j.token);",
              "  } catch (e) {}",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"postman-mock-login-001\",\n  \"zhili_vid\": \"postman_anon_001\"\n}"
        },
        "url": "{{base_url}}/api/user/login",
        "description": "需 WECHAT_MOCK=1 或 WECHAT_APPID+SECRET。成功后将 token 写入 Collection Variable `token`（与下方 /me 的 Bearer {{token}} 对应）。"
      }
    },
    {
      "name": "GET /api/user/me",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/user/me",
        "description": "Bearer 使用 Collection 或 Environment 中的 `token`（先跑 Login）。"
      }
    },
    {
      "name": "GET /api/user/recommend (B3)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/user/recommend?occasion=birthday&budget=100-300&style=practical&offset=0&limit=10&zhili_group=B",
        "description": "需先 Login，且已有默认画像（可先 POST /api/profile）。响应含 mode 与 list（ProductCard[]）。zhili_group=A 为热门对照。"
      }
    },
    {
      "name": "GET /api/recommend (B4)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/recommend?page=1&size=10&occasion=birthday&budget=100-300&style=practical&zhili_group=B",
        "description": "B4：网关分页 `page`/`size`；需默认画像。第二次 Send 可验证 Redis 命中（需已起 Redis，如 `npm run dev:db`）。"
      }
    },
    {
      "name": "GET /api/product/p001 (B5)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/product/p001",
        "description": "B5：商品详情，默认无登录即可 200。若需登录态理由：Authorization → Bearer {{token}}（需默认画像）。第二次 Send 可验 Redis（需已起 Redis）。"
      }
    },
    {
      "name": "POST /api/favorite (B6)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"p001\"\n}"
        },
        "url": "{{base_url}}/api/favorite",
        "description": "B6：需先 Login；`npm run seed` 后 `p001` 在 `product` 表。首次 **201**；重复 Send **200** + `already: true`。"
      }
    },
    {
      "name": "GET /api/favorite/list (B6)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/favorite/list?offset=0&limit=20",
        "description": "B6：`{ list, total }`，项为 `productId` + `createdAt`。"
      }
    },
    {
      "name": "DELETE /api/favorite/p001 (B6)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "DELETE",
        "header": [],
        "url": "{{base_url}}/api/favorite/p001",
        "description": "B6：成功 **204** 无 body；未收藏时 **404** `NOT_IN_COLLECTION`。"
      }
    },
    {
      "name": "GET /api/profile (B2)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/profile?offset=0&limit=20",
        "description": "需先 Login。返回 `{ list, total }`。"
      }
    },
    {
      "name": "POST /api/profile (B2)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  try {",
              "    const j = pm.response.json();",
              "    if (j.profile && j.profile.id != null) pm.collectionVariables.set('profile_id', String(j.profile.id));",
              "  } catch (e) {}",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman 画像\",\n  \"is_default\": false,\n  \"relation\": \"friend\",\n  \"ageBand\": \"26-35\",\n  \"interests\": [\"tech\"],\n  \"occasion\": \"birthday\",\n  \"budget\": \"100-300\",\n  \"gender\": \"male\",\n  \"style\": \"practical\",\n  \"taboos\": []\n}"
        },
        "url": "{{base_url}}/api/profile",
        "description": "首条画像时服务端会强制默认；多画像时可设 `is_default`。成功 **201** 时 Tests 写入 `profile_id`。"
      }
    },
    {
      "name": "GET /api/profile/default (B2)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/profile/default",
        "description": "无默认画像时 **404**（`NO_DEFAULT_PROFILE`）。"
      }
    },
    {
      "name": "GET /api/profile/:id (B2)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/profile/{{profile_id}}",
        "description": "请先跑「POST /api/profile」以写入 `profile_id`，或手填 Collection Variable。"
      }
    },
    {
      "name": "PUT /api/profile/:id/default (B2)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "PUT",
        "header": [],
        "url": "{{base_url}}/api/profile/{{profile_id}}/default",
        "description": "将指定画像设为默认（需有效 `profile_id`）。"
      }
    },
    {
      "name": "GET /api/hot",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/hot?occasion=birthday&budget=100-300&style=practical&offset=0&limit=5"
      }
    },
    {
      "name": "POST /api/personalized",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"relation\": \"friend\",\n  \"ageBand\": \"26-35\",\n  \"interests\": [\"tech\", \"home\"],\n  \"occasion\": \"birthday\",\n  \"budget\": \"100-300\",\n  \"gender\": \"male\",\n  \"style\": \"practical\",\n  \"taboos\": [],\n  \"shelf\": {\n    \"occasion\": \"birthday\",\n    \"budget\": \"100-300\",\n    \"style\": \"practical\"\n  },\n  \"offset\": 0,\n  \"limit\": 10\n}"
        },
        "url": "{{base_url}}/api/personalized"
      }
    },
    {
      "name": "GET /api/related/p001",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/related/p001?profile=%7B%22relation%22%3A%22friend%22%2C%22ageBand%22%3A%2226-35%22%2C%22interests%22%3A%5B%22tech%22%5D%2C%22occasion%22%3A%22birthday%22%2C%22budget%22%3A%22100-300%22%2C%22gender%22%3A%22male%22%2C%22style%22%3A%22practical%22%2C%22taboos%22%3A%5B%5D%7D",
        "description": "可选禁用 Params 中的 profile 对比无画像时的 reasons。"
      }
    },
    {
      "name": "POST /api/collect",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"page_view\",\n  \"user_id\": \"postman_test_user\",\n  \"group\": \"B\",\n  \"page_name\": \"browse\",\n  \"timestamp\": 1710000000000\n}"
        },
        "url": "{{base_url}}/api/collect",
        "description": "无 Auth。若 server 设置 EVENT_DB_DUAL_WRITE=1 且已连 MySQL，成功后另写 event 表。"
      }
    },
    {
      "name": "POST /api/event (B7)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"impression\",\n  \"user_id\": \"postman_event_anon\",\n  \"group\": \"B\",\n  \"page_name\": \"browse\",\n  \"product_id\": \"p001\",\n  \"position\": 0,\n  \"timestamp\": 1710000000001\n}"
        },
        "url": "{{base_url}}/api/event",
        "description": "B7：需 MySQL。匿名时 event.user_id 为 NULL，user_id 字符串在 extra。可改 Auth 为 Bearer {{token}} 验证登录态 user_id 入库。"
      }
    },
    {
      "name": "GET /api/export/events.csv",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/export/events.csv",
        "description": "需先至少成功一次 collect 以生成 events.csv。"
      }
    },
    {
      "name": "B9 /api/admin/products",
      "description": "需先 Login。server `.env`：`ZHILI_ADMIN_USER_IDS=<你的 user.id>` 或 `ZHILI_DEV_ADMIN_ANY_USER=1`（仅本地）。",
      "item": [
        {
          "name": "GET /api/admin/products (list)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/admin/products?limit=10&offset=0"
          }
        },
        {
          "name": "GET /api/admin/products/p001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/admin/products/p001"
          }
        },
        {
          "name": "POST /api/admin/products",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"z9_postman_1\",\n  \"title\": \"Postman 测试商品\",\n  \"price\": 9.99,\n  \"gender\": \"any\",\n  \"images\": [\"https://picsum.photos/seed/z9post/400/400\"],\n  \"styles\": [\"practical\"],\n  \"occasions\": [\"birthday\", \"universal\"],\n  \"interests\": [\"tech\"],\n  \"hotRank\": 900\n}"
            },
            "url": "{{base_url}}/api/admin/products"
          }
        },
        {
          "name": "PUT /api/admin/products/z9_postman_1",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman 测试商品（已改）\",\n  \"affiliateUrl\": \"https://example.com/aff/z9\"\n}"
            },
            "url": "{{base_url}}/api/admin/products/z9_postman_1"
          }
        },
        {
          "name": "DELETE /api/admin/products/z9_postman_1",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/admin/products/z9_postman_1"
          }
        }
      ]
    }
  ]
}
