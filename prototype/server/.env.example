# 知礼 MVP 服务端（B0：MySQL + Redis，复制为 .env 后按需修改）
# 本机 Docker 一键：在 prototype 目录执行 npm run dev:db（见 prototype/README.md）
# 首次若不用 Docker，请先在 MySQL 中建库，例如：
# CREATE DATABASE IF NOT EXISTS zhili_mvp CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=zhili_mvp

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=   # 仅当 Redis 启用了 requirepass 时填写；prototype/docker-compose 默认无密码

# API 端口（被占用时会顺延，见 prototype/README.md）
# PORT=3000

# —— B1 微信登录（与 develop2 §9.2 一致）——
# 生产/联调真机：填写小程序 AppID + AppSecret
# WECHAT_APPID=
# WECHAT_SECRET=
# 本地无密钥时：WECHAT_MOCK=1，任意非空 code 会映射为稳定 mock openid
# WECHAT_MOCK=1
# JWT_SECRET=请改为随机长串（勿用默认值）
# JWT_EXPIRES_IN=7d

# —— B7 埋点入库（develop2 §9.8）——
# collect 落盘 jsonl/csv 成功后，额外 INSERT `event` 表；DB 失败不影响 collect 的 { ok: true }
# EVENT_DB_DUAL_WRITE=1

# —— B9 商品写 /api/admin/products*（develop2 §9.9.5）——
# 与 GET /api/user/me 返回的 user.id 一致，逗号分隔；或签发 JWT 时带 { role: 'admin' }
# ZHILI_ADMIN_USER_IDS=1,2
# 仅本地：任意登录用户可写管理接口（禁止上生产）
# ZHILI_DEV_ADMIN_ANY_USER=1
