# 与本目录上级 docker-compose.yml 中 MySQL 默认配置一致（仅本机 Docker 开发）
# 一键脚本会将此文件复制为 .env（若尚不存在 .env）

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=zhili_mvp

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 本仓库 docker-compose 中 Redis 未设 requirepass，勿填 REDIS_PASSWORD

# B1：本地可开 WECHAT_MOCK=1；生产务必 WECHAT_APPID/SECRET + 随机 JWT_SECRET
